# RabbitMQ Connection (Required)
USERNAME=admin
PASSWORD=admin

# For RabbitMQ running on host machine (Mac/Windows):
RABBITMQ_URL=http://host.docker.internal:15672

# For RabbitMQ running on different server:
# RABBITMQ_URL=http://your-rabbitmq-server:15672

# For Linux with host networking (uncomment network_mode in docker-compose.yml):
# RABBITMQ_URL=http://localhost:15672

# Optional Configuration
VHOST=/
DEFINITIONS_FILE=definitions.json
PORT=8077